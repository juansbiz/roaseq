{
  "name": "roaseq",
  "version": "1.2.0",
  "description": "ROASEQ attribution app (FOSS subset). The self-hostable attribution engine that gets cherry-picked to the public roaseq repo. Open-source ecommerce attribution platform. The FOSS alternative to Triple Whale. Multi-touch attribution, channel ROI, journey stitching. Your events, your models, your database.",
  "license": "AGPL-3.0",
  "author": {
    "name": "Juan (juansbiz)",
    "email": "juan@hificopy.com",
    "url": "https://github.com/juansbiz"
  },
  "homepage": "https://roaseq.com",
  "repository": {
    "type": "git",
    "url": "https://git.antieq.com/juansbiz/roaseq.git"
  },
  "bugs": {
    "url": "https://github.com/juansbiz/roaseq/issues",
    "email": "juan@hificopy.com"
  },
  "keywords": [
    "attribution",
    "multi-touch",
    "triple-whale-alternative",
    "foss",
    "agpl",
    "self-hosted",
    "postgresql",
    "typescript",
    "react",
    "ecommerce"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "npx -y npm-force-resolutions",
    "validate:config": "node scripts/validate-config.js",
    "validate:imports": "node scripts/validate-imports.js",
    "translations:sync": "node scripts/translations/sync-translations.js",
    "translations:sync:dry": "node scripts/translations/sync-translations.js --dry-run",
    "translations:validate": "node scripts/translations/validate-translations.js",
    "predev": "npm run validate:config",
    "prebuild:prod": "npm run validate:config && npm run translations:validate",
    "dev": "vite --host",
    "dev:vite": "vite --host",
    "dev:docker": "concurrently \"npm run docker:up\" \"npm run dev:vite\" --names \"DOCKER,VITE\" --prefix-colors \"blue,cyan\" --kill-others",
    "dev:full": "npm run dev:docker",
    "dev:build": "npm run build && npm run start",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "build:prod": "npm run prebuild:prod && NODE_ENV=production vite build",
    "build:sentry": "NODE_ENV=production SENTRY_AUTH_TOKEN=$SENTRY_AUTH_TOKEN vite build",
    "preview": "vite preview",
    "backend": "npm run docker:up",
    "backend:local": "nodemon src/backend/index.js",
    "backend:prod": "node src/backend/index.js",
    "check-typos": "node scripts/check-component-typos.js",
    "pre-commit": "npm run check-typos && npm run validate:config && npm run translations:validate",
    "start": "node src/backend/index.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop roaseq",
    "pm2:restart": "pm2 restart roaseq",
    "pm2:logs": "pm2 logs roaseq",
    "pm2:delete": "pm2 delete roaseq",
    "check": "npm run lint && npm run build",
    "lint": "eslint \"frontend/**/*.{js,jsx,ts,tsx}\" --max-warnings=0",
    "format": "prettier -w .",
    "seed": "node scripts/seed-demo-data.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:funnels": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns=funnels",
    "test:auth": "node scripts/test-auth-system.js",
    "test:health": "node scripts/comprehensive-system-health-test.js",
    "test:comprehensive": "node scripts/test-comprehensive-suite.js",
    "test:e2e": "node scripts/test-comprehensive-suite.js",
    "test:rate-limits": "bash scripts/test-rate-limit-fix.sh",
    "flush:rate-limits": "bash scripts/flush-rate-limits.sh",
    "verify:schema": "node scripts/verify-users-schema.js",
    "deploy:schema": "node scripts/deploy-users-schema.js",
    "migrate": "node scripts/run-migration.js",
    "migrate:workflow": "node scripts/run-migration.js 003_workflow_schema_clean.sql",
    "services:check": "./scripts/check-services.sh",
    "services:chromadb": "./scripts/start-chromadb.sh",
    "services:redis": "brew services start redis",
    "deploy:backup": "./scripts/deploy-backup.sh",
    "deploy:prepare": "npm run deploy:backup && npm run test:comprehensive && npm run verify:schema",
    "migrate:test": "node scripts/test-migration-setup.js",
    "migrate:verify": "node scripts/verify-migrations.js",
    "migrate:inject": "node scripts/inject-sql.js",
    "migrate:cli": "supabase db push",
    "migrate:cli:dry": "supabase db push --dry-run",
    "create:route": "node backend/scripts/create-cached-route.js",
    "stripe:verify": "node scripts/verify-stripe-setup.js",
    "stripe:webhooks": "stripe listen --forward-to localhost:3002/api/v1/stripe/webhook",
    "stripe:webhooks:bg": "node scripts/manage-stripe-webhooks.js start",
    "stripe:webhooks:stop": "node scripts/manage-stripe-webhooks.js stop",
    "stripe:webhooks:status": "node scripts/manage-stripe-webhooks.js status",
    "stripe:logs": "tail -f logs/stripe-webhooks.log",
    "stripe:products": "stripe products list",
    "stripe:prices": "stripe prices list --limit 20",
    "stripe:update-price": "node scripts/update-stripe-price.js",
    "stripe:sync": "node scripts/sync-stripe-products.js",
    "stripe:test": "node scripts/test-stripe-integration.js",
    "docker:build": "cd docker/backend && docker-compose build",
    "docker:up": "./scripts/docker-start.sh",
    "docker:down": "./scripts/docker-stop.sh",
    "docker:logs": "cd docker/backend && docker-compose logs -f",
    "docker:restart": "npm run docker:down && npm run docker:up"
  },
